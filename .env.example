# --------------------------------------------------
# CONFIGURATION ENVIRONMENT VARIABLES
# --------------------------------------------------

# Logging Configuration
LOG_LEVEL=INFO

# Whisper Model Configuration
# Options: small, medium, large-v3, turbo
# "turbo" is balanced, "large-v3" is high quality, "small" is low RAM
WHISPER_MODEL=turbo

# Preferred Device Configuration
# Options: cuda, mps, cpu
# Automatically falls back to next best device if unavailable
DEVICE_PREFERENCE=mps

# Confidence threshold for transcription
# Below this, the output text will be prefixed with [Low Confidence]
WHISPER_CONFIDENCE_THRESHOLD=0.6

# Hugging Face Access Token
# Required for downloading pyannote speaker diarization models
# Get it from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Audio File Constraints
# Max size in bytes (default: 100MB)
MAX_FILE_SIZE_BYTES=104857600
# Max duration in seconds (default: 1 hour)
MAX_AUDIO_DURATION_SECONDS=3600

# Output Directories
RAW_AUDIO_DIR=audio/raw
NORMALIZED_AUDIO_DIR=audio/normalized
OUTPUT_DIR=output
LOGS_DIR=logs
